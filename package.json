{
  "name": "slidev-theme-ice",
  "version": "0.0.1",
  "description": "ICE Malta course material theme for Slidev",
  "type": "module",
  "keywords": [
    "slidev-theme",
    "slidev",
    "ice",
    "ice-malta"
  ],
  "engines": {
    "slidev": ">=52.0.0"
  },
  "scripts": {
    "demo": "slidev example/slides.md --open",
    "demo:build": "slidev build example/slides.md"
  },
  "dependencies": {
    "appshots": "^1.2.1",
    "qrcode.vue": "^3.9.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.2",
    "vue": "^3.5.13"
  },
  "files": [
    "assets",
    "components",
    "layouts",
    "setup",
    "styles",
    "templates"
  ],
  "slidev": {
    "colorSchema": "light",
    "defaults": {
      "highlighter": "shiki",
      "transition": "slide-left",
      "canvasWidth": 1920,
      "aspectRatio": "16/9"
    }
  }
}
